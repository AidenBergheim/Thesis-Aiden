@article{wang_limit-cycle-based_2017,
	title = {Limit-{Cycle}-{Based} {Decoupled} {Design} of {Circle} {Formation} {Control} with {Collision} {Avoidance} for {Anonymous} {Agents} in a {Plane}},
	volume = {62},
	copyright = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/IEEE.html},
