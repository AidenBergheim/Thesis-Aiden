	pages = {168--182},
	file = {PDF:C\:\\Users\\aiden\\Zotero\\storage\\T7G8FBQE\\Chen et al. - 2023 - Target localization and multicircular circumnavigation with bearing‐only measurements.pdf:application/pdf},
}

@article{chen_cooperative_2023,
	title = {Cooperative localization and circumnavigation of multiple targets with bearing-only measurements},
