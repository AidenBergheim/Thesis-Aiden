}

@article{sui_unified_nodate,
	title = {A {Unified} {Approach} to {Bearing}-{Only} {Target} {Localization} and {Circumnavigation} with {Two} {Timescales}},
	abstract = {This paper presents a general controller design framework for the bearing-only target localization and circumnavigation (BoTLC) problem. Based on the singular perturbation approach and Tikhonov’s extended theorem, we introduce a novel adaptive target estimator that decouples the BoTLC problem, which is traditionally treated as a dual control problem in the literature, into two subsystems evolving on different timescales. On this basis, we provide a unified approach to controller design and convergence analysis. To illustrate the efficacy and simplicity of the proposed framework, we reinterpret established controllers from the literature within this design methodology. Comprehensive simulations are provided to demonstrate the efficacy of the proposed design framework.},
