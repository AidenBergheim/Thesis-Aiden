classdef Agent_Nonholonomic

    properties (Access = public)

        % ---- State variables ----
            p                   % 2x1 vector: current agent position [x; y]
            p_dot               % 2x1 vector: current agent velocity [vx; vy]
            p_traj              % 2xT matrix: agent position history over time
            heading             % Scalar: agent heading angle (rad)
            heading_dot
            heading_dot_traj
    
        % ---- Target-related measurements ----
            d                   % 1xT cell: each cell contains 1xN vector of true distances to N targets
            varphi              % 1xN cell: each cell contains 2x1 vector of bearing components to target
            bar_varphi          % 1xN cell: each cell contains 2x1 vector of bearing components perpendicular to target
            varphi_traj         % 1xN cell: each cell contains 2xT matrix of bearing components over time
            psi                 % Scalar: current bearing angle to targets centroid (rad)
            bar_psi             % Scalar: estimated bearing angle to targets centroid (rad)
            projPoint           % 2x1 vector: coordinates of current projection point
    
        % ---- Target state estimators ----
            x_hat               % 1xN cell: each cell contains 2xT matrix of estimated target positions over time
            x_hat_curr
            x_hat_dot           % 1xN cell: each cell contains 2xT matrix of target position derivatives over time
            P                   % 1xN cell: each cell contains 1xT cell of 2x2 covariance matrices
            q                   % 1xN cell: each cell contains 1xT cell of 2x1 process noise vectors
        
        % ---- Estimated distances and errors ----
            d_hat               % 1xN vector: estimated distances to N targets
            d_convex_hat        % Scalar: estimated distance to convex hull of targets
            d_tilde             % 1xN vector: distance estimation errors (d_hat - true distance)
            theta_tilde
            u                   % 2x1 vector: current velocity command
            u_angle
            v
            c                   % 2x1 vector: Actual targets centroid position
            c_hat               % 2x1 vector: Estimated targets centroid position
            localization_heading

    
        % ---- Control gains and parameters ----
            k_omega             % Scalar: control gain for angular velocity
            d_des               % Scalar: desired distance to target
            d_des_dot
            d_des_func
            d_des_traj 
            alpha_0
            alpha_1             % Scalar: control parameter for distance error dynamics
            alpha_2             % Scalar: control parameter for bearing error dynamics
            Tc0
            Tc1                 % Scalar: control time constant
            Tc2                 % Scalar: control time constant

        % ---- Xu et al. prescribed-time controller parameters ----
            xu_p_int            % Integer p: order parameter (2p > n+1, n=1 so p>=1)
            xu_eps              % Scalar: prescribed steady-state accuracy epsilon
            xu_c_param          % Scalar: constraint scaling c > 0
            xu_c0               % Scalar: control gain on transformed error xi_1
            xu_zeta0            % Scalar: disturbance rejection gain (zeta >= D*phi(t))
            xu_sigma_hat        % Scalar: adaptive estimate of D^2 (disturbance bound squared)
            xu_lambda           % Scalar: adaptive law forgetting gain
            xu_r1               % Scalar: Young's inequality weighting parameter
    
        % ---- Logging / diagnostics ----
            delta_traj          % 1xT vector: history of bearing angle offsets
            theta_error_traj
            d_convex_true       % Scalar: true distance to convex hull
            varrho_traj         % 1xT vector: history of distances to projection point
            x_tilde_traj        % 1xT vector: history of target position estimation errors
            projPoint_traj      % 2xT matrix: history of projection point coordinates
            true_hull_vertices  % Mx2 matrix: coordinates of true convex hull vertices
            d_hat_dot           % 1xN vector: time derivatives of estimated distances
            theta_traj
            theta
            integral
            integralss
            
        % ---- Trajectory type for delta calculation ----
            trajectory_type     % String: 'hull', 'circle', or 'ellipse'

    end

    methods

        % Initialisation of agent
        function obj = Agent_Nonholonomic(p_0, x_hat_0_cell, k_omega, Tc0, Tc1, Tc2, alpha_0, alpha_1, alpha_2, d_des_function_handle, tSteps, numTargets, targets, heading)
           
            % Initial agent state
            obj.p = p_0;                                 % Initial position (2x1)
            obj.p_dot = zeros(2, 1);                     % Velocity (2x1)
            obj.p_traj = zeros(2, tSteps);               % Position trajectory (2xT)
            obj.heading = heading;                       % Initial heading (scalar)
            obj.heading_dot = 0;
            obj.heading_dot_traj = zeros(1, tSteps);
            obj.u_angl
        
            % Control parameters
            obj.k_omega = k_omega;                       % Angular velocity gain
            obj.Tc0 = Tc0;
            obj.Tc1 = Tc1;                               % Time constant 1
            obj.Tc2 = Tc2;                               % Time constant 2
            obj.alpha_0 = alpha_0;
            obj.alpha_1 = alpha_1;                       % Control gain α₁
            obj.alpha_2 = alpha_2;                       % Control gain α₂
            obj.d_des_func = d_des_function_handle;
            obj.d_des = 2;
            obj.d_des_dot = zeros(1, tSteps);
            obj.d_des_traj = zeros(1, tSteps);
            obj.theta_traj = zeros(1, tSteps);
            obj.integral = zeros(1, tSteps);
            obj.integralss = zeros(1, tSteps);

            % ---- Xu et al. controller defaults ----
            % These can be overridden after construction if needed.
            % p_int: must satisfy 2*p_int > n+1. For n=1 (scalar radial error), p=1 suffices.
            % p=2 is used here for smoother derivatives of beta(t).
            obj.xu_p_int   = 2;
            obj.xu_eps     = 0.05;   % Steady-state accuracy ε — tune to task requirements
            obj.xu_c_param = 100;    % Constraint scaling c > 0
            obj.xu_c0      = 2.0;    % Control gain on transformed error ξ₁
            obj.xu_zeta0   = 0.5;    % Disturbance rejection gain (needs zeta >= D*phi(t))
            obj.xu_sigma_hat = 0;    % Initial adaptive disturbance estimate σ̂ = D̂²
            obj.xu_lambda    = 1.0;  % Adaptive law forgetting rate λ
            obj.xu_r1        = 0.01; % Young's inequality weighting r₁
        
            % Distance measurements
            obj.d = cell(1, tSteps);                     % True distances to each target
            obj.d_tilde = 0;                             % Distance error
            obj.theta_tilde = 0;
            obj.c = mean(targets, 2);
            obj.v = 0;
        
            % Bearing vectors
            obj.varphi = cell(1, numTargets);            % Bearing vector to target
            obj.bar_varphi = cell(1, numTargets);        % Normalised bearing vector
            obj.varphi_traj = cell(1, numTargets);       % Bearing trajectory over time
        
            % Target state estimates
            obj.x_hat = cell(1, numTargets);             % Estimated target position
            obj.x_hat_dot = cell(1, numTargets);         % Estimated target velocity
            obj.d_hat = cell(1, numTargets);             % Estimated agent-target distance
            obj.d_hat_dot = zeros(1, numTargets);        % Estimated distance rate
        
            % Projection and auxiliary variables
            obj.psi = zeros(2, 1);                       % Auxiliary vector ψ
            obj.bar_psi = zeros(2, 1);                   % Estimated ψ
            obj.projPoint = zeros(2, 1);                 % Projection point on hull
        
            % Estimation parameters
            obj.P = cell(1, numTargets);                 % Covariance matrices
            obj.q = cell(1, numTargets);                 % Filter bias terms
        
            % Trajectory tracking variables
            obj.delta_traj = zeros(1, tSteps);           % Control error δ trajectory
            obj.theta_error_traj = zeros(1, tSteps);
            obj.d_convex_true = zeros(1, tSteps);        % True convex hull distance
            obj.varrho_traj = cell(1, numTargets);       % Varrho trajectory per target
            obj.x_tilde_traj = cell(1, numTargets);      % Target position estimation error
            obj.projPoint_traj = zeros(2, tSteps);       % Projection point trajectory
            obj.localization_heading = zeros(2,1);
        
            % Initialise per-target variables
            for i = 1:numTargets
                obj.varphi_traj{i} = zeros(2, tSteps);           % Bearing trajectory
                obj.x_hat{i} = zeros(2, tSteps);                 % Target position estimate
                obj.x_hat{i}(:, 1) = x_hat_0_cell(:, i);         % Initial position estimate
                obj.x_hat_dot{i} = zeros(2, tSteps);             % Target velocity estimate
        
                obj.P{i} = cell(1, tSteps);
                obj.P{i}{1} = zeros(2, 2);
                obj.q{i} = cell(1, tSteps);
                obj.q{i}{1} = zeros(2, 1);
        
                obj.varrho_traj{i} = zeros(1, tSteps);           % Varrho trajectory
                obj.x_tilde_traj{i} = zeros(2, tSteps);          % Position estimation error
            end

            initial_estimates = zeros(2, numTargets);
            for i = 1:numTargets
                initial_estimates(:, i) = obj.x_hat{i}(:, 1);
            end
            obj.c_hat = mean(initial_estimates, 2);
            obj.theta = atan2(obj.p(2) - obj.c_hat(2), obj.p(1) - obj.c_hat(1));
            obj.theta_traj(1,:) = obj.theta;
        end


        function obj = updateDesiredDistance(obj, cur_tStep, dT)
            t = cur_tStep;
            current_time = t * dT;
            
            % Get number of targets
            numTargets = length(obj.x_hat);
            
            % Extract estimated positions (2 x numTargets)
            x_hat_positions = zeros(2, numTargets);
            for i = 1:numTargets
                x_hat_positions(:, i) = obj.x_hat{i}(:, cur_tStep);
            end
        
            theta = atan2(obj.p(2) - obj.c_hat(2), obj.p(1) - obj.c_hat(1));

            obj.theta_traj(t) = theta;
        
            obj.d_des = obj.d_des_func(current_time, theta, x_hat_positions, obj.c_hat, obj.p);
            
            obj.d_des_traj(t) = obj.d_des;
            if t > 1
                obj.d_des_dot(t) = (obj.d_des_traj(t) - obj.d_des_traj(t-1)) / dT;
            else
                obj.d_des_dot(t) = 0;
            end
        end

        % Getting bearing measurement to each target
        function obj = getBearings(obj, cur_tStep, targets)
            t = cur_tStep;
            numTargets = size(targets, 2);
            distances = zeros(1, numTargets);
            varphi_matrix = zeros(2, numTargets);
            % Bearings to each target
            for i = 1:numTargets
                % Only using distance to target for plotting and to
                % calculate bearing, not actually used by agent algorithms
                target_pos = targets(:, i);  
                d_i = norm(target_pos - obj.p);
                distances(i) = d_i;
                obj.varphi{i} = (target_pos - obj.p) / d_i;
                varphi_matrix(:, i) = obj.varphi{i};
                % Finding bar_varphi, the rotated pi/2 vector of varphi
                obj.bar_varphi{i} = [ cos(pi/2), sin(pi/2);
                                    -sin(pi/2), cos(pi/2)] * obj.varphi{i};
            end
            % Bearings to centroid (This is the "average phi" method, not bisector)
            obj.psi = (obj.c - obj.p) / norm((obj.c - obj.p));
            obj.bar_psi = [ cos(pi/2), sin(pi/2);
                            -sin(pi/2), cos(pi/2)] * obj.psi;
            
            obj.delta_traj(t) = norm(obj.c_hat - obj.p) - obj.d_des;
            
            
            % --- CORRECTED LOCALIZATION HEADING ---
            if obj.localization_heading == zeros(2,1)
                % 1. Get all angles
                angles = atan2(varphi_matrix(2, :), varphi_matrix(1, :));
            
                % 2. Find min and max angles
                min_angle = min(angles);
                max_angle = max(angles);
                
                % 3. Find the bisecting angle
                bisect_angle = (min_angle + max_angle) / 2;
                
                % 4. Handle the wrap-around case (if arc is > 180 deg)
                if (max_angle - min_angle) > pi
                    bisect_angle = bisect_angle + pi;
                end
                
                % 5. Calculate the PERPENDICULAR angle (add 90 degrees)
                perp_angle = bisect_angle - (pi/2);
                
                % 6. Normalize angle to [-pi, pi]
                perp_angle = wrapToPi(perp_angle);
                
                % 7. Convert this perpendicular angle into a 2x1 unit vector
                obj.localization_heading = [cos(perp_angle); sin(perp_angle)];
            end
        end


        % Individual target estimator from Sui et al. (2025)
        function obj = estimateTargetPDT(obj, cur_tStep, dT, targets, Tc1)
            t = cur_tStep;
            numTargets = size(targets, 2);
            latest_x_hats = zeros(2, numTargets);
            
            for i = 1:numTargets

                % Estimate each target
                if t*dT < Tc1
                    if t <= 2
                        obj.x_hat_dot{i}(:, t) = zeros(2, 1);
                    else
                        % Finding x_hat_dot
                        xi = inv(obj.P{i}{t}) * (obj.P{i}{t} * obj.x_hat{i}(:, t) - obj.q{i}{t});
                        if norm(xi) == 0
                            Psi_a = zeros(2, 1);
                        else
                            Psi_a = xi ./ (norm(xi) ^ obj.alpha_1);
                        end
                        obj.x_hat_dot{i}(:, t) = -1 / (obj.Tc1 * obj.alpha_1) * exp(norm(xi) ^ obj.alpha_1) * Psi_a;
                    end
                    % Updating kreisselmeier's regressor
                    P_dot = -obj.P{i}{t} + obj.bar_varphi{i} * obj.bar_varphi{i}.';
                    q_dot = -obj.q{i}{t} + obj.bar_varphi{i} * obj.bar_varphi{i}.' * obj.p;
                    obj.P{i}{t+1} = obj.P{i}{t} + P_dot * dT;
                    obj.q{i}{t+1} = obj.q{i}{t} + q_dot * dT;

                % Just continue propogating values if past Tc1
                else
                    obj.x_hat_dot{i}(:, t) = zeros(2, 1); % Assume static target
                    obj.P{i}{t+1} = obj.P{i}{t};         % Propagate P
                    obj.q{i}{t+1} = obj.q{i}{t};         % Propagate q
                end

                if t + 1 <= size(obj.x_hat{i}, 2)
                    obj.x_hat{i}(:, t+1) = obj.x_hat{i}(:, t) + obj.x_hat_dot{i}(:, t) * dT;
                end
                latest_x_hats(:, i) = obj.x_hat{i}(:, t);
                obj.x_tilde_traj{i}(:, t) = obj.x_hat{i}(:, t) - targets(:, i);

            end
            
            % This must also always run, as updateDesiredDistance depends on it
            obj.c_hat = mean(latest_x_hats, 2);
        end

        function obj = controlInputPDTHolonomic(obj, t, dT)

            % Error in distance to shape
            obj.d_tilde = norm(obj.c - obj.p) - obj.d_des;
            
            
            if (t*dT > obj.Tc1 + obj.Tc2)
                obj.integral(t+1) = obj.integral(t) + obj.d_tilde* dT;
            else
                obj.integral(t+1) = obj.integral(t);
            end

            
            if t*dT < obj.Tc1
                obj.u = obj.k_omega  * obj.localization_heading;
            else
                v_cen = 1/(obj.alpha_2 * obj.Tc2) * exp(abs(obj.d_tilde) ^ obj.alpha_2) * sig(obj.d_tilde, 1 - obj.alpha_2) - obj.d_des_dot(t);
                
                obj.u = v_cen * obj.psi + obj.k_omega  * obj.bar_psi;

            end

            % Compute heading_dot only — do NOT update obj.heading here, let move() do it
            if norm(obj.u) > 1e-10
                new_heading = atan2(obj.u(2), obj.u(1));
            else
                new_heading = obj.heading;
            end
        
            obj.heading_dot = wrapToPi(new_heading - obj.heading) / dT;
        end

        function obj = controlInputPDTv1(obj, t, dT)
            % Error in distance to shape
            obj.d_tilde = norm(obj.c - obj.p) - obj.d_des;
            
            if t*dT < obj.Tc1
                f_i = obj.k_omega  * obj.localization_heading;
            else
                v_cen = 1/(obj.alpha_2 * obj.Tc2) * exp(abs(obj.d_tilde) ^ obj.alpha_2) * sig(obj.d_tilde, 1 - obj.alpha_2) - obj.d_des_dot(t);
                f_i = v_cen * obj.psi + obj.k_omega  * obj.bar_psi;
            end

            obj.u = f_i;
            
            % Heading unit vectors
            h_i    = [cos(obj.heading); sin(obj.heading)];   % forward direction
            h_perp = [-sin(obj.heading); cos(obj.heading)];  % perpendicular (left)
        
            % Linear velocity: projection of f_i onto heading (eq. 8)
            obj.v = h_i' * f_i;
        
            % This rotates h_i toward f_i, i.e. h_dot = (I - h_i*h_i') * f_i
            obj.heading_dot = h_perp' * f_i;
        end

        % Calculating Control input for controller inspired by Sui et al. (2025)
        function obj = controlInputPDTv2(obj, t, dT)

            % Error in distance to shape
            obj.d_tilde = norm(obj.c - obj.p) - obj.d_des;
            
            if t*dT < obj.Tc1
                obj.u = obj.k_omega  * obj.localization_heading;
            else
                v_cen = 1/(obj.alpha_2 * obj.Tc2) * exp(abs(obj.d_tilde) ^ obj.alpha_2) * sig(obj.d_tilde, 1 - obj.alpha_2) - obj.d_des_dot(t);
                obj.u = v_cen * obj.psi + obj.k_omega  * obj.bar_psi;
            end
            theta_d = atan2(obj.u(2), obj.u(1));
            obj.theta_tilde = wrapToPi(obj.heading - theta_d);
            %obj.heading_dot = -50*obj.theta_tilde;
            obj.v = [cos(obj.heading); sin(obj.heading)]' * obj.u;
            obj.heading_dot = -1/(obj.alpha_0 * obj.Tc0) * exp(abs(obj.theta_tilde) ^ obj.alpha_0) * sig(obj.theta_tilde, 1 - obj.alpha_0);

        end
        

        % =========================================================================
        % controlInputPDTv3  —  Three-Phase Cascade for Rigorous Predefined-Time
        %                       Convergence under Nonholonomic Constraints
        % =========================================================================
        %
        % THEORETICAL BASIS
        % -----------------
        % The three-phase cascade is the only approach that preserves the exact
        % assumptions of Bergheim's (2025) stability proof while enforcing the
        % unicycle's nonholonomic constraint.  The key idea is to make the
        % unicycle *behave identically to a single integrator* during each phase
        % where the proof requires it.
        %
        % Phase 0  [0, Tc0)              — Heading Alignment
        %   The agent is held STATIONARY (v = 0).  A prescribed-time scalar
        %   controller drives the heading error
        %
        %       theta_tilde := wrap(heading - theta_des_localise)
        %
        %   to zero within Tc0, using the Lemma 1 controller:
        %
        %       heading_dot = -(1/(alpha_0 * Tc0)) * exp(|theta_tilde|^alpha_0)
        %                     * sig(theta_tilde, 1 - alpha_0)
        %
        %   Because v = 0, all geometric initial conditions of Assumption 1
        %   (Bergheim) remain exactly satisfied at t = Tc0.  The heading
        %   convergence proof is a direct scalar application of Lemma 1.
        %
        % Phase 1  [Tc0, Tc0 + Tc1)      — Localisation
        %   With heading aligned to chi_bar and held fixed (heading_dot = 0),
        %   the agent moves at constant speed v = k_omega in a straight line.
        %   The actual velocity is
        %
        %       p_dot = k_omega * [cos(heading); sin(heading)]
        %             = k_omega * chi_bar          (after Phase 0 alignment)
        %
        %   This is *identical* to the single-integrator assumption.  Every step
        %   from Proposition 2 through Theorem 1 of Bergheim holds without
        %   modification.
        %
        % Phase 2  [Tc0 + Tc1, Tc0 + Tc1 + Tc2)  — Circumnavigation
        %   The holonomic circumnavigation law f_i is computed as in v1/v2.
        %   A nested prescribed-time heading controller (same Lemma 1 form,
        %   budget Tc0) aligns h_i with f_i / ||f_i|| within Tc0 << Tc2.
        %   The linear velocity is set to v = ||f_i|| so that once heading is
        %   aligned:
        %
        %       p_dot = v * h_i = ||f_i|| * (f_i / ||f_i||) = f_i
        %
        %   exactly recovering the single-integrator dynamics needed by
        %   Proposition 1 and Theorem 2.
        %
        %   The overall convergence time budget is Tc0 + Tc1 + Tc0 + Tc2,
        %   where the second Tc0 is consumed by heading alignment at the start
        %   of Phase 2, and the remaining Tc2 is available for radial error
        %   convergence.
        %
        % OVERALL PREDEFINED-TIME GUARANTEE
        % ----------------------------------
        %   T_total = Tc0  +  Tc1  +  Tc0  +  Tc2
        %             |         |       |        |
        %          Phase 0   Phase 1  Ph2 hd  Phase 2
        %          align     localise  align   circumnavigate
        %
        %   All four components are user-specified tunable parameters.
        %
        % PARAMETERS USED
        % ---------------
        %   obj.alpha_0          — exponent for heading prescribed-time controller
        %   obj.Tc0              — prescribed time for heading alignment (both
        %                          Phase 0 and Phase 2 inner loop)
        %   obj.k_omega          — straight-line speed ks during Phase 1
        %   obj.alpha_2          — exponent for radial circumnavigation controller
        %   obj.Tc2              — prescribed time for radial convergence
        %   obj.localization_heading — unit vector chi_bar (set during getBearings)
        %
        % =========================================================================
        
        function obj = controlInputPDTv3(obj, t, dT)

            current_time = t * dT;
        
            % Maximum heading rate (rad/s) — prevents Euler integration blow-up
            % from the exp term in the prescribed-time controller.
            % Set to a physically reasonable value for your platform.
            omega_max = 10.0;  % rad/s — tune to hardware limits
        
            % =================================================================
            % PHASE 0  [0, Tc0)  —  Heading Alignment (agent stationary)
            %
            % Agent holds position (v = 0) while heading rotates to align with
            % localization direction chi_bar.  Because nothing translates,
            % Bergheim Assumption 1 remains exactly satisfied at t = Tc0.
            % Convergence follows directly from Lemma 1 on the scalar system
            %   d/dt(theta_tilde) = heading_dot,   V = |theta_tilde|
            % which has a fixed target (localization_heading never changes).
            % =================================================================
            if current_time < obj.Tc0
        
                obj.v = 0;
        
                % Desired heading: fixed direction chi_bar
                theta_des = atan2(obj.localization_heading(2), ...
                                  obj.localization_heading(1));
        
                obj.theta_tilde = wrapToPi(obj.heading - theta_des);
        
                % Lemma 1 controller — target is fixed so no feed-forward needed
                raw_hdot = -1 / (obj.alpha_0 * obj.Tc0) ...
                           * exp(abs(obj.theta_tilde)^obj.alpha_0) ...
                           * sig(obj.theta_tilde, 1 - obj.alpha_0);
        
                obj.heading_dot = max(-omega_max, min(omega_max, raw_hdot));
                obj.u = [0; 0];
        
            % =================================================================
            % PHASE 1  [Tc0, Tc0 + Tc1)  —  Localisation
            %
            % Heading is aligned and held fixed.  Agent moves at constant speed
            % k_omega in direction chi_bar.  Actual velocity equals the
            % single-integrator assumption exactly:
            %   p_dot = k_omega * chi_bar
            % Bergheim Propositions 2-8 and Theorem 1 apply without modification.
            % =================================================================
            elseif current_time < obj.Tc0 + obj.Tc1
        
                obj.heading_dot = 0;
                obj.v           = obj.k_omega;
                obj.u           = obj.k_omega * obj.localization_heading;
        
                theta_des       = atan2(obj.localization_heading(2), ...
                                        obj.localization_heading(1));
                obj.theta_tilde = wrapToPi(obj.heading - theta_des);
        
            % =================================================================
            % PHASE 2  [Tc0 + Tc1, Tc0 + Tc1 + Tc2)  —  Circumnavigation
            %
            % The holonomic law f_i is computed from Sui et al.  A nested
            % prescribed-time heading controller aligns h_i with f_i.
            %
            % Three fixes over the naive version:
            %   (a) Feed-forward of theta_des_dot — the desired heading rotates
            %       at the orbital rate; without this the controller chases a
            %       moving target and theta_tilde never converges to zero.
            %   (b) Speed modulated by cos(theta_tilde) — prevents large
            %       velocities in wrong directions during misalignment.
            %   (c) Saturation on heading_dot — prevents Euler blow-up from
            %       the exp term for large initial heading errors.
            % =================================================================
            else
        
                % -------------------------------------------------------------
                % Step 1: Holonomic circumnavigation law f_i  (Sui et al. 2025)
                % -------------------------------------------------------------
                obj.d_tilde = norm(obj.c_hat - obj.p) - obj.d_des;
        
                v_cen = 1 / (obj.alpha_2 * obj.Tc2) ...
                        * exp(abs(obj.d_tilde)^obj.alpha_2) ...
                        * sig(obj.d_tilde, 1 - obj.alpha_2) ...
                        - obj.d_des_dot(t);
        
                f_i   = v_cen * obj.psi + obj.k_omega * obj.bar_psi;
                obj.u = f_i;
        
                % -------------------------------------------------------------
                % Step 2: Desired heading and its rate of change
                %
                % theta_des = atan2(f_i(2), f_i(1)) rotates as the agent
                % orbits.  The angular rate of psi (and bar_psi) is the orbital
                % angular rate zeta_dot = k_omega / d(t) [rad/s].
                %
                % Adding this as feed-forward converts the time-varying target
                % problem back to a regulation problem on theta_tilde, so the
                % Lemma 1 convergence argument becomes valid:
                %
                %   d/dt(theta_tilde) = heading_dot - theta_des_dot
                %                     = [theta_des_dot + feedback] - theta_des_dot
                %                     = feedback
                %                     = Lemma 1 form -> 0 within Tc0
                % -------------------------------------------------------------
                % --- Step 2: Compute f_i and current desired heading ---
                d_current = norm(obj.c_hat - obj.p);
                f_i = v_cen * obj.psi + obj.k_omega * obj.bar_psi;
                obj.u = f_i;
                
                if norm(f_i) > 1e-10
                    theta_des_now = atan2(f_i(2), f_i(1));
                
                    % --- Step 2b: Estimate heading settle time tau ---
                    %
                    % The prescribed-time heading controller drives theta_tilde to zero
                    % within the heading budget Tc0. A conservative (safe) estimate of
                    % the remaining time until theta_tilde ~ 0 is simply proportional
                    % to |theta_tilde| / pi, scaled by Tc0. This under-estimates for
                    % large errors (good — don't over-predict) and gives tau -> 0 as
                    % the heading converges (prediction collapses to reactive).
                    %
                    % Alternative: use a fixed tau = 0.5 * Tc0 (half the heading budget).
                    % That's coarser but doesn't require knowing theta_tilde at this point
                    % in the code. Both are valid.
                    
                    tau_heading = obj.Tc0 * (abs(obj.theta_tilde) / pi);
                    % clamp to something sensible — never predict further than one Tc0
                    tau_heading = min(tau_heading, obj.Tc0);
                
                    % --- Step 2c: Predictive angular advance ---
                    %
                    % The desired heading rotates at orbital rate k_omega / d(t) rad/s
                    % (the angular velocity of the centroid-relative position vector psi).
                    % Over tau_heading seconds, the orbit sweeps Δθ radians.
                    % We add this to theta_des_now to get where f_i will point when
                    % heading has finished settling.
                    %
                    % Sign convention: k_omega > 0 gives CCW orbit, so Δθ > 0 means
                    % the heading target advances CCW — which is correct.
                
                    if d_current > 1e-6
                        Delta_theta = (obj.k_omega / d_current) * tau_heading;
                    else
                        Delta_theta = 0;
                    end
                
                    theta_des_pred = theta_des_now + Delta_theta;
                
                    % --- Step 2d: Orbital rate feed-forward (unchanged) ---
                    if d_current > 1e-6
                        theta_des_dot = obj.k_omega / d_current;
                    else
                        theta_des_dot = 0;
                    end
                
                else
                    theta_des_pred = obj.heading;
                    theta_des_dot  = 0;
                end
                
                % --- Step 3: Heading controller drives toward predicted target ---
                %
                % Note: we use theta_des_pred (the predictive target), not theta_des_now.
                % The feed-forward theta_des_dot is still computed at the *current*
                % geometry — it compensates for the rotation of the target during
                % the control step, which is a separate (instantaneous) effect.
                
                obj.theta_tilde = wrapToPi(obj.heading - theta_des_pred);
                
                feedback_term = -1 / (obj.alpha_0 * obj.Tc0) ...
                                * exp(abs(obj.theta_tilde)^obj.alpha_0) ...
                                * sig(obj.theta_tilde, 1 - obj.alpha_0);
                
                raw_hdot        = theta_des_dot + feedback_term;
                obj.heading_dot = max(-omega_max, min(omega_max, raw_hdot));
                
                % Step 4: linear velocity — unchanged
                obj.v = norm(f_i) * max(0, cos(obj.theta_tilde));
        
            end
        
        end

        % Moving agent with holonomic agent constraints
        function obj = move(obj, dT, t)
            obj.p_dot = obj.u;
            obj.p = obj.p + obj.p_dot * dT;
            obj.p_traj(:, t) = obj.p;

            if norm(obj.u) > 1e-10
                new_heading = atan2(obj.u(2), obj.u(1));
            else
                new_heading = obj.heading;
            end
        
            obj.heading_dot_traj(t) = wrapToPi(new_heading - obj.heading) / dT;
            obj.heading = new_heading;
        end

        % Moving agent with non-holonomic constraints
        % Using the control input projection method from Zhao et al. (2019)
        % To control a planar unicycle model
        function obj = moveNonHolonomic(obj, dT, t)
            
            % Updating non-holonomic model
            x_dot = obj.v * cos(obj.heading);
            y_dot = obj.v * sin(obj.heading);
            theta_dot = obj.heading_dot;
            
            % Store velocity
            obj.p_dot = [x_dot; y_dot];
            
            % Integration to find new agent pose
            obj.p(1) = obj.p(1) + x_dot * dT;
            obj.p(2) = obj.p(2) + y_dot * dT;
            obj.heading = obj.heading + theta_dot * dT;
            
            % Normalize heading to [-pi, pi]
            obj.heading = atan2(sin(obj.heading), cos(obj.heading));
            
            % Store trajectories
            obj.p_traj(:, t) = obj.p;
            obj.theta_error_traj(t) = wrapToPi(obj.heading - atan2(obj.u(2), obj.u(1)));
            obj.heading_dot_traj(t) = obj.heading_dot;
        end
        
    end
end